// CBI Viale — schema Prisma
// DB: Neon PostgreSQL. Runtime usa DATABASE_URL (pooled), migraciones DIRECT_URL.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================================================
//  AUTH
// ============================================================================

enum UserRole {
  ADMIN
  EMPLOYEE
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  role          UserRole  @default(EMPLOYEE)
  permissions   Json      @default("{}")
  active        Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts  Account[]
  sessions  Session[]
  auditLogs AuditLog[]

  @@index([email])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============================================================================
//  SERVICIOS
// ============================================================================

enum ServiceSlug {
  CLINICA_HUMANA
  VETERINARIA
  AGRO_ALIMENTOS
  AMBIENTAL
  MEDICINA_REGENERATIVA
  GENETICA
}

model Service {
  id               String      @id @default(cuid())
  slug             ServiceSlug @unique
  name             String
  shortDescription String
  longDescription  String      @db.Text
  heroImage        String?
  iconName         String?
  durationMinutes  Int         @default(30)
  requiresConsent  Boolean     @default(false)
  active           Boolean     @default(true)
  order            Int         @default(0)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  images          ServiceImage[]
  analyses        ServiceAnalysis[]
  appointments    Appointment[]
  formSubmissions FormSubmission[]
  blockedDates    BlockedDate[]
  availability    AvailabilityRule[]
}

model ServiceImage {
  id        String  @id @default(cuid())
  serviceId String
  url       String
  alt       String
  order     Int     @default(0)
  service   Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@index([serviceId, order])
}

model ServiceAnalysis {
  id          String  @id @default(cuid())
  serviceId   String
  name        String
  description String?
  order       Int     @default(0)
  service     Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@index([serviceId, order])
}

// ============================================================================
//  TURNOS
// ============================================================================

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}

model Appointment {
  id            String            @id @default(cuid())
  serviceId     String
  date          DateTime
  durationMin   Int
  status        AppointmentStatus @default(PENDING)

  patientName   String
  patientDni    String
  patientEmail  String
  patientPhone  String
  notes         String?           @db.Text
  consentGiven  Boolean           @default(false)

  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  confirmedAt   DateTime?
  cancelledAt   DateTime?
  cancelReason  String?

  service       Service           @relation(fields: [serviceId], references: [id])
  emailLogs     EmailLog[]

  @@index([date, status])
  @@index([patientEmail])
  @@index([patientDni])
  @@index([serviceId, date])
}

// ============================================================================
//  DISPONIBILIDAD
// ============================================================================

enum Weekday {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

model AvailabilityRule {
  id        String   @id @default(cuid())
  weekday   Weekday
  startTime String   // "08:00"
  endTime   String   // "12:00"
  serviceId String?  // null = aplica a todos los servicios
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  service   Service? @relation(fields: [serviceId], references: [id])

  @@index([weekday, active])
  @@index([serviceId])
}

model BlockedDate {
  id        String   @id @default(cuid())
  startDate DateTime
  endDate   DateTime
  reason    String?
  serviceId String?
  createdBy String
  createdAt DateTime @default(now())

  service   Service? @relation(fields: [serviceId], references: [id])

  @@index([startDate, endDate])
  @@index([serviceId])
}

// ============================================================================
//  FORMULARIOS
// ============================================================================

enum FormType {
  CONTACT_GENERAL
  SERVICE_INQUIRY
  CONSENT
  CUSTOM
}

enum FormStatus {
  PENDING
  ANSWERED
  ARCHIVED
}

model FormSubmission {
  id         String     @id @default(cuid())
  type       FormType
  serviceId  String?
  name       String
  email      String
  phone      String?
  subject    String?
  message    String     @db.Text
  extraData  Json       @default("{}")
  status     FormStatus @default(PENDING)
  answeredAt DateTime?
  answeredBy String?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  service    Service?   @relation(fields: [serviceId], references: [id])

  @@index([type, status])
  @@index([createdAt])
  @@index([email])
}

// ============================================================================
//  EMAIL
// ============================================================================

enum EmailKind {
  APPOINTMENT_CONFIRMATION
  APPOINTMENT_REMINDER_24H
  APPOINTMENT_CANCELLED
  FORM_RECEIPT
  INTERNAL_NOTIFICATION
}

enum EmailStatus {
  QUEUED
  SENT
  FAILED
  BOUNCED
}

model EmailLog {
  id            String       @id @default(cuid())
  kind          EmailKind
  to            String
  subject       String
  status        EmailStatus  @default(QUEUED)
  providerId    String?
  error         String?
  appointmentId String?
  sentAt        DateTime?
  createdAt     DateTime     @default(now())

  appointment   Appointment? @relation(fields: [appointmentId], references: [id])

  @@index([appointmentId])
  @@index([status, kind])
}

// ============================================================================
//  AUDITORÍA Y ANALYTICS
// ============================================================================

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  entity    String
  entityId  String?
  metadata  Json     @default("{}")
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([entity, entityId])
}

model PageView {
  id        String   @id @default(cuid())
  path      String
  referrer  String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([path, createdAt])
}

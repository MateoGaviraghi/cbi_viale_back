# ============================================================================
#  CBI Viale — Backend · Variables de entorno (template)
#  Copiar a `.env` y completar. El boot valida con zod (src/config/env.schema.ts)
#  y FALLA si falta una variable requerida (sin default).
# ============================================================================

# Entorno
NODE_ENV=development
PORT=3001

# Database (Neon) — REQUERIDAS
# DATABASE_URL: pooled connection (runtime). DIRECT_URL: direct (migraciones/db push).
DATABASE_URL="postgresql://user:pass@host/db?sslmode=require"
DIRECT_URL="postgresql://user:pass@host/db?sslmode=require"

# JWT — REQUERIDAS (mínimo 32 chars cada una)
JWT_SECRET="<32+ chars aleatorios>"
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET="<32+ chars aleatorios, distinto a JWT_SECRET>"
JWT_REFRESH_EXPIRES_IN=7d

# Cookies
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false
# COOKIE_SECRET — REQUERIDA (mínimo 32 chars). Secret dedicado para firmar cookies,
# separado de JWT_SECRET (F6). Generar con: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
COOKIE_SECRET="<32+ chars aleatorios, distinto a los JWT>"

# CORS (lista separada por comas)
CORS_ORIGINS="http://localhost:3000,https://cbi-viale-front.vercel.app"

# Redis (BullMQ — cola de emails). Necesario para que los POST que disparan email
# (turnos / submissions) no queden encolando contra un Redis caído.
REDIS_URL="redis://localhost:6379"

# Resend (emails)
RESEND_API_KEY=""
RESEND_FROM_EMAIL="CBI Viale <no-reply@cbiviale.com.ar>"
RESEND_REPLY_TO="contacto@cbiviale.com.ar"
BUSINESS_NOTIFICATION_EMAIL="contacto@cbiviale.com.ar"

# Swagger (solo se monta fuera de producción — F10)
SWAGGER_USER=admin
SWAGGER_PASSWORD=""

# Logging
LOG_LEVEL=info

# Seed (solo se usan al correr `npm run db:seed`)
SEED_ADMIN_EMAIL=admin@cbiviale.com.ar
# SEED_ADMIN_PASSWORD — REQUERIDA, mínimo 12 chars, SIN default (F8). Usar una
# password fuerte y aleatoria; rotarla si alguna vez se usó `cbi-admin-<año>`.
SEED_ADMIN_PASSWORD="<password fuerte, 12+ chars>"

# Cloudinary (uploads firmados — opcional; si faltan, /uploads/* devuelve 503).
# Endurecer el upload_preset en la consola de Cloudinary (formatos/tamaños) — F9.
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
CLOUDINARY_UPLOAD_FOLDER="cbi-viale/medical-orders"
CLOUDINARY_SIGNATURE_FOLDER="cbi-viale/consent-signatures"
CLOUDINARY_UPLOAD_PRESET="cbi_viale"

# Profesional firmante del consentimiento (snapshot en el PDF)
PROFESSIONAL_SIGNATURE_URL=""
PROFESSIONAL_NAME="Nahir Gastaldi"
PROFESSIONAL_ROLE="Bioquímica · CBI Viale"
